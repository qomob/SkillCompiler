{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Skill IR (Intermediate Representation)",
  "description": "Pass 1-3 产出的中间表示，是 Pass 4 生成的输入。Pass 3→4 Decision Gate 校验此 schema。",
  "type": "object",
  "required": ["meta", "pass_1_analyze", "pass_2_extract", "pass_3_design"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["compiler_version", "source_prompt_hash", "created_at", "target_platform", "compilation_mode"],
      "properties": {
        "compiler_version": { "type": "string" },
        "source_prompt_hash": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" },
        "target_platform": {
          "type": "string",
          "enum": ["trae", "claude", "generic"],
          "description": "目标宿主平台。Pass 0 确定后写入，Pass 4 按 profile 渲染输出。"
        },
        "compilation_mode": {
          "type": "string",
          "enum": ["quick", "full", "audit"],
          "description": "编译模式。quick 跳过非关键 Pass，full 完整编译，audit 只评估已有 skill。"
        },
        "token_budget": {
          "type": "object",
          "description": "Token 预算控制。Pass 0 设定总预算上限，超限时降级模式。",
          "properties": {
            "total_budget": {
              "type": "number",
              "description": "编译过程总 token 预算上限。0 表示无限制。"
            },
            "mode_change_at_pct": {
              "type": "number",
              "minimum": 0,
              "maximum": 100,
              "description": "当已消耗 token 达到预算的此百分比时，自动降级模式（如 full → quick）。默认 80。"
            },
            "current_estimate": {
              "type": "number",
              "description": "当前已估算的 token 消耗。每次 Pass 完成后更新。"
            }
          }
        },
        "platform_profile_applied": {
          "type": "boolean",
          "description": "是否已应用目标平台 profile 生成/检查。Pass 4 确认后设为 true。"
        }
      }
    },
    "pass_1_analyze": {
      "type": "object",
      "required": ["prompt_summary", "prompt_goal", "input_spec", "output_spec", "capability_hints", "boundary"],
      "properties": {
        "prompt_summary": { "type": "string" },
        "prompt_goal": {
          "type": "object",
          "required": ["stated", "actual"],
          "properties": {
            "stated": { "type": "string" },
            "actual": { "type": "string" }
          }
        },
        "input_spec": {
          "type": "object",
          "required": ["type", "description"],
          "properties": {
            "type": { "type": "string", "enum": ["string", "file", "api", "mixed"] },
            "description": { "type": "string" },
            "inferred": { "type": "boolean", "default": false }
          }
        },
        "output_spec": {
          "type": "object",
          "required": ["type", "description"],
          "properties": {
            "type": { "type": "string", "enum": ["string", "json", "file", "report"] },
            "description": { "type": "string" },
            "inferred": { "type": "boolean", "default": false }
          }
        },
        "capability_hints": {
          "type": "array",
          "items": { "type": "string" }
        },
        "boundary": {
          "type": "object",
          "required": ["in_scope", "out_of_scope"],
          "properties": {
            "in_scope": { "type": "array", "items": { "type": "string" } },
            "out_of_scope": { "type": "array", "items": { "type": "string" } }
          }
        },
        "hidden_assumptions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "unknowns": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "pass_2_extract": {
      "type": "object",
      "required": ["capability_graph", "knowledge_inventory", "role_matrix"],
      "properties": {
        "capability_graph": {
          "type": "object",
          "required": ["primary", "secondary", "graph"],
          "properties": {
            "primary": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
            "secondary": { "type": "array", "items": { "type": "string" } },
            "graph": { "type": "object" }
          }
        },
        "knowledge_inventory": {
          "type": "object",
          "properties": {
            "rules": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["content", "source", "target_file"],
                "properties": {
                  "content": { "type": "string" },
                  "source": { "type": "string", "enum": ["from source prompt", "inferred"] },
                  "target_file": { "type": "string" }
                }
              }
            },
            "templates": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "structure", "target_file"],
                "properties": {
                  "name": { "type": "string" },
                  "structure": { "type": "string" },
                  "target_file": { "type": "string" }
                }
              }
            },
            "domain_knowledge": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["content", "domain", "target_file"],
                "properties": {
                  "content": { "type": "string" },
                  "domain": { "type": "string" },
                  "target_file": { "type": "string" }
                }
              }
            },
            "examples": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "content", "target_file"],
                "properties": {
                  "type": { "type": "string", "enum": ["minimal", "normal", "complex", "edge-case", "failure", "anti-pattern"] },
                  "content": { "type": "string" },
                  "target_file": { "type": "string" }
                }
              }
            },
            "standards": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["type", "content", "target_file"],
                "properties": {
                  "type": { "type": "string", "enum": ["scoring", "quality", "acceptance"] },
                  "content": { "type": "string" },
                  "target_file": { "type": "string" }
                }
              }
            },
            "best_practices": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["content", "target_file"],
                "properties": {
                  "content": { "type": "string" },
                  "target_file": { "type": "string" }
                }
              }
            }
          }
        },
        "role_matrix": {
          "type": "object",
          "required": ["existing", "to_add"],
          "properties": {
            "existing": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "responsibility", "capabilities", "should_split"],
                "properties": {
                  "name": { "type": "string" },
                  "responsibility": { "type": "string" },
                  "capabilities": { "type": "array", "items": { "type": "string" } },
                  "should_split": { "type": "boolean" },
                  "split_reason": { "type": "string" }
                }
              }
            },
            "to_add": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name", "reason", "responsibility"],
                "properties": {
                  "name": { "type": "string" },
                  "reason": { "type": "string" },
                  "responsibility": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "pass_3_design": {
      "type": "object",
      "required": ["architecture_type", "single_skill_pattern", "module_decomposition", "folder_structure", "self_test_cases"],
      "properties": {
        "architecture_type": { "type": "string", "enum": ["single-prompt", "workflow", "multi-agent"] },
        "workflow_pattern": { "type": ["string", "null"] },
        "single_skill_pattern": { "type": "string", "enum": ["tool-wrapper", "generator", "reviewer", "inversion", "pipeline"] },
        "self_test_cases": {
          "type": "object",
          "description": "Pass 3 从 boundary + capability_graph 派生的静态自测用例。Pass 6 Layer B/C 的 test oracle。",
          "required": ["positive", "negative", "near_miss"],
          "properties": {
            "positive": {
              "type": "array",
              "description": "应触发：boundary.in_scope × capability_graph.primary 的组合",
              "items": { "type": "string" }
            },
            "negative": {
              "type": "array",
              "description": "不应触发：boundary.out_of_scope",
              "items": { "type": "string" }
            },
            "near_miss": {
              "type": "array",
              "description": "易误触发：capability_graph.secondary 与 primary 的差集",
              "items": { "type": "string" }
            }
          }
        },
        "module_decomposition": {
          "type": "object",
          "required": ["core_prompt"],
          "properties": {
            "core_prompt": { "type": "string" },
            "workflows": { "type": "array", "items": { "type": "string" } },
            "references": { "type": "array", "items": { "type": "string" } },
            "checklists": { "type": "array", "items": { "type": "string" } },
            "rubrics": { "type": "array", "items": { "type": "string" } },
            "templates": { "type": "array", "items": { "type": "string" } },
            "configs": { "type": "array", "items": { "type": "string" } }
          }
        },
        "workflow_steps": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "purpose", "input", "output"],
            "properties": {
              "id": { "type": "string" },
              "purpose": { "type": "string" },
              "input": { "type": "string" },
              "output": { "type": "string" },
              "decision_gate": { "type": "string" },
              "exit_criteria": { "type": "string" },
              "retry_strategy": { "type": "string" },
              "rollback_strategy": { "type": "string" }
            }
          }
        },
        "reference_tree": { "type": "array", "items": { "type": "string" } },
        "folder_structure": { "type": "string" }
      }
    },
    "conditional_passes": {
      "type": "object",
      "properties": {
        "plugins": {
          "type": "object",
          "properties": {
            "executed": { "type": "boolean" },
            "triggered_by": { "type": "array", "items": { "type": "string" } },
            "plugins_identified": { "type": "array" }
          }
        },
        "examples": {
          "type": "object",
          "properties": {
            "executed": { "type": "boolean" },
            "triggered_by": { "type": "array", "items": { "type": "string" } },
            "examples_generated": { "type": "array" }
          }
        }
      }
    }
  }
}
